<%- include('partials/header') %>

<div class="min-h-screen bg-gray-100 flex items-center justify-center p-6">

  <!-- MAIN CARD: Added 'border border-gray-200' and 'shadow-2xl' -->
  <div class="w-full max-w-lg bg-white p-8 rounded-2xl border border-gray-200 shadow-2xl">

    <!-- TITLE -->
    <h1 class="text-2xl font-extrabold mb-6 text-black flex items-center gap-2">
      <span class="material-icons text-blue-600">bar_chart</span>
      Stats
    </h1>

    <!-- SUMMARY GRID: Added border and shadow to small cards -->
    <div class="grid grid-cols-3 gap-3 mb-6 text-center">

      <div class="bg-blue-50 border border-blue-100 shadow-sm p-4 rounded-xl">
        <p class="text-sm text-black font-medium">Attempts</p>
        <p id="totalAttempts" class="font-bold text-blue-600 text-lg"></p>
      </div>

      <div class="bg-green-50 border border-green-100 shadow-sm p-4 rounded-xl">
        <p class="text-sm text-black font-medium">Best</p>
        <p id="bestScore" class="font-bold text-green-600 text-lg"></p>
      </div>

      <div class="bg-yellow-50 border border-yellow-100 shadow-sm p-4 rounded-xl">
        <p class="text-sm text-black font-medium">Last</p>
        <p id="lastScore" class="font-bold text-yellow-600 text-lg"></p>
      </div>

    </div>

    <!-- GRAPH SECTION -->
    <h2 class="font-bold mb-3 text-black">Performance Trend</h2>

    <!-- Graph Container: Added border and shadow -->
    <div class="bg-gray-50 border border-gray-200 shadow-inner rounded-xl p-4">
      <svg id="trendLine" class="w-full h-56"></svg>
    </div>

    <!-- HISTORY SECTION -->
    <h2 class="font-bold mt-6 mb-3 text-black">📜 History</h2>
    <ul id="history" class="space-y-3 text-sm"></ul>

    <!-- BACK BUTTON (Nav Style): Added border and shadow -->
    <div class="mt-8 text-center pt-4 border-t border-gray-100">
      <a href="/"
         class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-xl border border-blue-700 shadow-lg transition transform hover:-translate-y-1 font-bold">
        <span class="material-icons text-sm">home</span>
        Home
      </a>
    </div>

  </div>
</div>

<script>
  const attempts = JSON.parse(localStorage.getItem("quizAttempts")) || [];

  document.getElementById("totalAttempts").innerText = attempts.length;
  document.getElementById("bestScore").innerText =
    localStorage.getItem("bestScore") || 0;
  document.getElementById("lastScore").innerText =
    localStorage.getItem("lastScore") || 0;

  const svg = document.getElementById("trendLine");

  if (attempts.length < 2) {
    svg.innerHTML = `
      <text x="50%" y="50%" text-anchor="middle" fill="black" font-size="14" font-weight="bold">
        Not enough data for trend
      </text>`;
  } else {
    const width = svg.clientWidth;
    const height = 210;
    const pad = { left: 55, right: 15, top: 15, bottom: 45 };
    const graphWidth = width - pad.left - pad.right;
    const graphHeight = height - pad.top - pad.bottom;
    const maxScore = Math.max(...attempts.map(a => a.total));

    const points = attempts.map((a, i) => {
      const x = pad.left + (i / (attempts.length - 1 || 1)) * graphWidth;
      const y = pad.top + graphHeight - (a.score / maxScore) * graphHeight;
      return { x, y };
    });

    const pointString = points.map(p => `${p.x},${p.y}`).join(" ");

    svg.innerHTML = `
      <!-- X AXIS -->
      <line x1="${pad.left}" y1="${height - pad.bottom}" x2="${width - pad.right}" y2="${height - pad.bottom}" stroke="black" stroke-width="2"/>
      <!-- Y AXIS -->
      <line x1="${pad.left}" y1="${pad.top}" x2="${pad.left}" y2="${height - pad.bottom}" stroke="black" stroke-width="2"/>
      <!-- LINE -->
      <polyline fill="none" stroke="#2563eb" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" points="${pointString}" />
      <!-- DOTS -->
      ${points.map(p => `<circle cx="${p.x}" cy="${p.y}" r="5" fill="#1e40af" stroke="white" stroke-width="1"></circle>`).join("")}
      <!-- X AXIS NUMBERS -->
      ${attempts.map((a, i) => {
        const x = pad.left + (i / (attempts.length - 1 || 1)) * graphWidth;
        return `<text x="${x}" y="${height - pad.bottom + 20}" text-anchor="middle" font-size="10" font-weight="bold" fill="black">${i + 1}</text>`;
      }).join("")}
      <!-- Y AXIS NUMBERS -->
      ${(() => {
        let labels = "";
        const steps = 4;
        for (let i = 0; i <= steps; i++) {
          const value = Math.round((maxScore / steps) * i);
          const y = pad.top + graphHeight - (i / steps) * graphHeight;
          labels += `<text x="${pad.left - 10}" y="${y + 4}" text-anchor="end" font-size="10" font-weight="bold" fill="black">${value}</text>`;
        }
        return labels;
      })()}
      <text x="${width / 2}" y="${height - 5}" text-anchor="middle" font-size="12" font-weight="bold" fill="black">Attempts</text>
      <text x="15" y="${height / 2}" text-anchor="middle" font-size="12" font-weight="bold" fill="black" transform="rotate(-90 15 ${height / 2})">Score</text>
    `;
  }

  const list = document.getElementById("history");
  attempts.slice().reverse().forEach(a => {
    const li = document.createElement("li");
    // Added border and shadow to each history item
    li.className = "p-3 bg-white border border-gray-200 shadow-sm rounded-xl flex justify-between items-center text-black font-medium";
    li.innerHTML = `
      <span>Score: <strong class="text-blue-600">${a.score}/${a.total}</strong></span>
      <span class="text-black text-xs font-bold">${a.date}</span>
    `;
    list.appendChild(li);
  });
</script>

<%- include('partials/footer') %>