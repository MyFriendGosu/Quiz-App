<%- include('partials/header') %>

<div class="min-h-screen flex items-center justify-center p-6 bg-gray-50">

  <div class="w-full max-w-2xl bg-white rounded-2xl shadow-xl p-6 relative">

    <!-- TOP BAR -->
    <div class="flex justify-between items-center mb-4">
      <div class="text-red-600 font-bold text-lg">
        ⏱ <span id="timer">15</span>s
      </div>
      <div id="question-count" class="text-gray-600 text-sm font-medium"></div>
    </div>

    <!-- PROGRESS BAR -->
    <div class="w-full bg-gray-200 h-2 rounded mb-6 overflow-hidden">
      <div id="progress-bar"
           class="bg-blue-500 h-2 transition-all duration-1000"
           style="width:100%"></div>
    </div>

    <!-- QUESTION -->
    <h2 id="question" class="text-xl font-semibold mb-6 text-gray-800"></h2>

    <!-- ANSWERS -->
    <div id="answers" class="space-y-3"></div>

  </div>
</div>

<!-- FEEDBACK DIALOG (Hidden by default) -->
<div id="feedback-modal" class="fixed inset-0 flex items-center justify-center z-50 hidden bg-black/50 backdrop-blur-sm px-4">
  <div class="bg-white rounded-3xl shadow-2xl p-8 max-w-sm w-full transform transition-all text-center">
    
    <!-- Icon Container -->
    <div id="feedback-status-icon" class="mx-auto flex items-center justify-center h-20 w-20 rounded-full mb-4">
      <!-- Icon (SVG or Emoji) will be injected by JS -->
    </div>

    <h3 id="feedback-title" class="text-2xl font-bold mb-2"></h3>
    <p id="feedback-message" class="text-gray-600 mb-8"></p>

    <button id="modal-next-btn" class="w-full py-4 bg-gray-900 hover:bg-black text-white font-bold rounded-2xl transition-colors duration-200 shadow-lg">
      Continue
    </button>
  </div>
</div>

<script src="/js/quiz.js"></script>

<%- include('partials/footer') %>